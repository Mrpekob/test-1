local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local sdFolder = workspace:WaitForChild("SD")

local allowedTools = {
    ["HEX Spitter"] = true,
    ["Whig gun deluxe"] = true,
}

local activeTargets = {}
local registeredModels = {}
local cachedRemote = nil

local function watchForTools(character)
    local backpack = player:FindFirstChild("Backpack")

    character.ChildAdded:Connect(function(child)
        if child:IsA("Tool") and allowedTools[child.Name] then
            cachedRemote = nil
        end
    end)

    character.ChildRemoved:Connect(function(child)
        if child:IsA("Tool") and allowedTools[child.Name] then
            cachedRemote = nil
        end
    end)

    if backpack then
        backpack.ChildAdded:Connect(function(child)
            if child:IsA("Tool") and allowedTools[child.Name] then
                cachedRemote = nil
            end
        end)
    end
end

local function getRemote()
    if cachedRemote and cachedRemote.Parent then
        return cachedRemote
    end

    cachedRemote = nil

    local char = player.Character
    if not char then return nil end
    local backpack = player:FindFirstChild("Backpack")

    for _, loc in ipairs({char, backpack}) do
        if not loc then continue end
        for toolName in pairs(allowedTools) do
            local tool = loc:FindFirstChild(toolName)
            if tool then
                local remotes = tool:FindFirstChild("Remotes")
                if remotes then
                    local remote = remotes:FindFirstChild("ServerControl")
                    if remote then
                        cachedRemote = remote
                        return remote
                    end
                end
            end
        end
    end

    return nil
end

local function hasShield(target)
    if not target then return false end
    if target:FindFirstChild("ForceField") then return true end
    if target:FindFirstChild("DestroyableFF") then return true end
    return false
end

local function registerTarget(target)
    if not target or target.Parent ~= sdFolder then return end
    if registeredModels[target] then return end
    registeredModels[target] = true

    task.spawn(function()
        local humanoid = target:WaitForChild("Humanoid", 10)
        if not humanoid then
            registeredModels[target] = nil
            return
        end

        local hitPart = target:FindFirstChild("HumanoidRootPart")
            or target:FindFirstChild("Torso")
            or target:FindFirstChild("Head")

        if not hitPart then
            task.wait(0.5)
            hitPart = target:FindFirstChild("HumanoidRootPart")
                or target:FindFirstChild("Torso")
                or target:FindFirstChild("Head")
        end

        if not hitPart then
            registeredModels[target] = nil
            return
        end

        if target.Parent == sdFolder and humanoid.Health > 0 then
            table.insert(activeTargets, {
                model = target,
                humanoid = humanoid,
                hitPart = hitPart
            })
        else
            registeredModels[target] = nil
        end
    end)
end

local function setupCharacter(character)
    cachedRemote = nil
    character:WaitForChild("HumanoidRootPart", 10)
    watchForTools(character)

    local humanoid = character:WaitForChild("Humanoid", 5)
    if humanoid then
        humanoid.Died:Connect(function()
            cachedRemote = nil
        end)
    end
end

if player.Character then
    setupCharacter(player.Character)
end

player.CharacterAdded:Connect(function(character)
    setupCharacter(character)
end)

-- Register existing targets
for _, child in ipairs(sdFolder:GetChildren()) do
    registerTarget(child)
end

-- Auto detect new entities
sdFolder.ChildAdded:Connect(function(newChild)
    registerTarget(newChild)
end)

-- Cleanup when entity removed from SD
sdFolder.ChildRemoved:Connect(function(removed)
    registeredModels[removed] = nil
    for i = #activeTargets, 1, -1 do
        if activeTargets[i].model == removed then
            table.remove(activeTargets, i)
            break
        end
    end
end)

-- Master heartbeat loop
RunService.Heartbeat:Connect(function()
    -- Hard stop if nothing to attack
    if #activeTargets == 0 then return end

    local remote = getRemote()
    if not remote then return end

    for i = #activeTargets, 1, -1 do
        local t = activeTargets[i]

        -- Remove dead or gone targets
        if not t.model.Parent or t.humanoid.Health <= 0 then
            registeredModels[t.model] = nil
            table.remove(activeTargets, i)
            continue
        end

        -- Skip shielded targets but keep in list
        if hasShield(t.model) then
            continue
        end

        task.spawn(function()
            pcall(function()
                remote:InvokeServer("RayHit", {
                    Hit = t.hitPart,
                    Position = t.hitPart.Position,
                })
            end)
        end)
    end
end)
