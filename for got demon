local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local sdFolder = workspace:WaitForChild("SD")

local allowedTools = {
    ["HEX Spitter"] = true,
    ["Whig gun deluxe"] = true,
}

local activeLoops = {} -- Track active loops to prevent duplicates

-- Cache remote to avoid searching every frame
local cachedRemote = nil
local cachedToolName = nil
local lastRemoteCheck = 0
local REMOTE_CACHE_TIME = 0.5

local function getRemote()
    local now = tick()

    -- Return cached if still valid
    if cachedRemote and (now - lastRemoteCheck) < REMOTE_CACHE_TIME then
        -- Verify cached remote still exists
        if cachedRemote.Parent then
            return cachedRemote
        end
        cachedRemote = nil
        cachedToolName = nil
    end

    local character = player.Character
    if not character then return nil end
    local backpack = player:FindFirstChild("Backpack")

    -- Check equipped tools first (character), then backpack
    local searchLocations = {character}
    if backpack then
        table.insert(searchLocations, backpack)
    end

    for _, location in ipairs(searchLocations) do
        for toolName in pairs(allowedTools) do
            local tool = location:FindFirstChild(toolName)
            if tool then
                local remotes = tool:FindFirstChild("Remotes")
                if remotes then
                    local serverControl = remotes:FindFirstChild("ServerControl")
                    if serverControl then
                        cachedRemote = serverControl
                        cachedToolName = toolName
                        lastRemoteCheck = now
                        return serverControl
                    end
                end
            end
        end
    end

    cachedRemote = nil
    cachedToolName = nil
    return nil
end

local function getTorso(target)
    return target:FindFirstChild("Torso")
        or target:FindFirstChild("HumanoidRootPart")
        or target:FindFirstChild("Head")
end

local function isValidTarget(target)
    if not target or not target.Parent then return false end
    if target.Parent ~= sdFolder then return false end

    -- Must have a humanoid-like body part to hit
    if not getTorso(target) then return false end

    -- Check if humanoid exists and is alive
    local humanoid = target:FindFirstChildOfClass("Humanoid")
    if humanoid and humanoid.Health <= 0 then return false end

    return true
end

local function startTargetLoop(target)
    local targetName = target.Name

    -- Prevent duplicate loops for same target
    if activeLoops[target] then return end
    activeLoops[target] = true

    task.spawn(function()
        local failCount = 0
        local MAX_FAILS = 10

        while isValidTarget(target) do
            local remote = getRemote()

            if remote then
                local torso = getTorso(target)

                if torso then
                    local success, err = pcall(function()
                        remote:InvokeServer("RayHit", {
                            Hit = torso,
                            Position = torso.Position,
                        })
                    end)

                    if success then
                        failCount = 0
                    else
                        failCount = failCount + 1
                        if failCount >= MAX_FAILS then
                            warn("[BF] Too many failures on " .. targetName .. ", stopping loop")
                            break
                        end
                    end
                end
            end

            task.wait(0.01)
        end

        activeLoops[target] = nil
    end)
end

-- Start loops for existing targets
for _, child in ipairs(sdFolder:GetChildren()) do
    if isValidTarget(child) then
        startTargetLoop(child)
    end
end

-- Auto-start for new targets
sdFolder.ChildAdded:Connect(function(newChild)
    -- Small delay to let the model fully load
    task.wait(0.1)
    if isValidTarget(newChild) then
        startTargetLoop(newChild)
    end
end)

-- Invalidate remote cache when tool changes
player.CharacterAdded:Connect(function(char)
    cachedRemote = nil
    cachedToolName = nil

    -- Re-check existing targets when respawning
    task.wait(1)
    for _, child in ipairs(sdFolder:GetChildren()) do
        if isValidTarget(child) and not activeLoops[child] then
            startTargetLoop(child)
        end
    end
end)

-- Cleanup dead loops periodically
task.spawn(function()
    while task.wait(5) do
        for target, _ in pairs(activeLoops) do
            if not isValidTarget(target) then
                activeLoops[target] = nil
            end
        end
    end
end)
