            if _G.BossClapperRunning then
                registerTargetBC(newChild)
            end
        end)
        table.insert(_G.BossClapperConnections, addedConn)

        local removedConn = sdFolderBC.ChildRemoved:Connect(function(removed)
            _G.BossClapperRegisteredModels[removed] = nil
            for i = #_G.BossClapperActiveTargets, 1, -1 do
                if _G.BossClapperActiveTargets[i].model == removed then
                    table.remove(_G.BossClapperActiveTargets, i)
