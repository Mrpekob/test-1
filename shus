    for _, conn in ipairs(nameHiderConnections) do
        pcall(function() conn:Disconnect() end)
    end
    nameHiderConnections = {}
    restoreAllTexts()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            pcall(function() showCharacterNames(player.Character) end)
        end
    end
    originalHumanoidSettings = {}
    originalBillboardSettings = {}
    originalBillboardTextSettings = {}
    updateHomePlayerCard()
end

