local function plainReplace(text, search, replace)
    if not search or search == "" then return text end
    local result = ""
    local searchLen = #search
    local i = 1
    while i <= #text do
        if text:sub(i, i + searchLen - 1) == search then
            result = result .. replace
            i = i + searchLen
        else
            result = result .. text:sub(i, i)
            i = i + 1
        end
    end
    return result
end

local function textContainsAnyName(text)
    if not text or text == "" then return false end
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Name and player.Name ~= "" and text:find(player.Name, 1, true) then return true end
        if player.DisplayName and player.DisplayName ~= "" and player.DisplayName ~= player.Name and text:find(player.DisplayName, 1, true) then return true end
    end
    return false
end

local function censorText(text)
    if not nameHiderEnabled then return text end
    if not text or text == "" then return text end
    local replacements = {}
    for _, player in ipairs(Players:GetPlayers()) do
        pcall(function()
            if player.Name and player.Name ~= "" then
                if player == LocalPlayer then
                    if player.DisplayName and player.DisplayName ~= "" and player.DisplayName ~= player.Name then
                        table.insert(replacements, {name = player.DisplayName, replace = customFakeName, len = #player.DisplayName})
                    end
                    table.insert(replacements, {name = player.Name, replace = customFakeName, len = #player.Name})
                else
                    if player.DisplayName and player.DisplayName ~= "" and player.DisplayName ~= player.Name then
                        table.insert(replacements, {name = player.DisplayName, replace = HIDDEN_PLACEHOLDER, len = #player.DisplayName})
                    end
                    table.insert(replacements, {name = player.Name, replace = HIDDEN_PLACEHOLDER, len = #player.Name})
                end
            end
        end)
    end
    table.sort(replacements, function(a, b) return a.len > b.len end)
    for _, rep in ipairs(replacements) do
        text = plainReplace(text, rep.name, rep.replace)
    end
    return text
end

local function watchTextObject(obj)
    if not obj then return end
    if isOurGui(obj) then return end
    pcall(function()
        if originalTexts[obj] == nil then originalTexts[obj] = obj.Text end
        local censored = censorText(obj.Text)
        if censored ~= obj.Text then obj.Text = censored end
        local conn = obj:GetPropertyChangedSignal("Text"):Connect(function()
            if not nameHiderEnabled or not guiAlive then return end
            if isOurGui(obj) then return end
            pcall(function()
                local currentText = obj.Text
                if currentText:find(HIDDEN_PLACEHOLDER, 1, true) then return end
                if customFakeName ~= LocalPlayer.Name and currentText:find(customFakeName, 1, true) then return end
                if textContainsAnyName(currentText) then
                    originalTexts[obj] = currentText
                    local newCensored = censorText(currentText)
                    if newCensored ~= currentText then obj.Text = newCensored end
                end
            end)
        end)
        table.insert(nameHiderConnections, conn)
    end)
end

