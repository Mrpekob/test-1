local function showCharacterNames(character)
    if not character then return end
    pcall(function()
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            local saved = originalHumanoidSettings[humanoid]
            if saved then
                humanoid.DisplayDistanceType = saved.DisplayDistanceType
                humanoid.NameDisplayDistance = saved.NameDisplayDistance
                humanoid.HealthDisplayDistance = saved.HealthDisplayDistance
                originalHumanoidSettings[humanoid] = nil
            else
                humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.Viewer
                humanoid.NameDisplayDistance = 100
                humanoid.HealthDisplayDistance = 100
            end
        end
    end)
    pcall(function()
        for _, obj in ipairs(character:GetDescendants()) do
            if obj:IsA("BillboardGui") then
                local saved = originalBillboardSettings[obj]
                if saved then
                    obj.Enabled = saved.Enabled
                    obj.MaxDistance = saved.MaxDistance
                    originalBillboardSettings[obj] = nil
                else
                    obj.Enabled = true
                    obj.MaxDistance = 100
                end
                for _, child in ipairs(obj:GetDescendants()) do
                    if child:IsA("TextLabel") or child:IsA("TextButton") then
                        local savedText = originalBillboardTextSettings[child]
                        if savedText then
                            child.TextTransparency = savedText.TextTransparency
                            child.BackgroundTransparency = savedText.BackgroundTransparency
                            originalBillboardTextSettings[child] = nil
                        else
                            child.TextTransparency = 0
                        end
                    end
                end
            end
        end
    end)
end

