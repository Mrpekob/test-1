        tw(keyInputFrame, 0.04, {Position = orig}, Enum.EasingStyle.Linear)
        task.wait(0.6)
        if not guiAlive then return end
        tw(keySubmit, 0.3, {BackgroundColor3 = C.accent})
        keySubmitText.Text = "Validate Key"
    end
end

