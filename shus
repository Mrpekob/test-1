                                return remote
                            end
                        end
                    end
                end
            end
            return nil
        end

        local function hasShieldBC(target)
            if not target then return false end
            if target:FindFirstChild("ForceField") then return true end
            if target:FindFirstChild("DestroyableFF") then return true end
            return false
        end

        local function registerTargetBC(target)
            if not _G.BossClapperRunning then return end
            if not target or target.Parent ~= sdFolderBC then return end
            if _G.BossClapperRegisteredModels[target] then return end
            _G.BossClapperRegisteredModels[target] = true

            task.spawn(function()
