    trackBG.BackgroundColor3 = C.toggleOff
    trackBG.BorderSizePixel = 0
    trackBG.ZIndex = 10
    trackBG.Parent = frame
    corner(trackBG, 2)
    local pct = (default - min) / (max - min)
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(pct, 0, 1, 0)
    fill.BackgroundColor3 = C.accent
    fill.BorderSizePixel = 0
    fill.ZIndex = 11
    fill.Parent = trackBG
    corner(fill, 2)
    local knobF = Instance.new("Frame")
    knobF.Size = UDim2.new(0, 12, 0, 12)
    knobF.Position = UDim2.new(pct, -6, 0.5, -6)
    knobF.BackgroundColor3 = C.white
    knobF.BorderSizePixel = 0
    knobF.ZIndex = 12
    knobF.Parent = trackBG
    corner(knobF, 6)
    local sliding = false
    local inputBtn = Instance.new("TextButton")
    inputBtn.Size = UDim2.new(1, 10, 0, 20)
    inputBtn.Position = UDim2.new(0, -5, 0, -8)
    inputBtn.BackgroundTransparency = 1
    inputBtn.Text = ""
    inputBtn.ZIndex = 13
    inputBtn.Parent = trackBG
    local function update(inputPos)
        if not guiAlive then return end
        local abs = trackBG.AbsolutePosition.X
        local w = trackBG.AbsoluteSize.X
        local rel = math.clamp((inputPos.X - abs) / w, 0, 1)
        local val = math.floor(min + (max - min) * rel + 0.5)
        local newPct = (val - min) / (max - min)
        fill.Size = UDim2.new(newPct, 0, 1, 0)
        knobF.Position = UDim2.new(newPct, -6, 0.5, -6)
        valLbl.Text = tostring(val)
        if callback then callback(val) end
    end
    inputBtn.MouseButton1Down:Connect(function() sliding = true end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if not guiAlive then return end
        if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then update(input.Position) end
    end)
    inputBtn.MouseButton1Click:Connect(function()
        if not guiAlive then return end
        update(UserInputService:GetMouseLocation())
    end)
    return frame
end

