    {name = "Settings", icon = "\xE2\x9A\x99", locked = true},
}

local tabPages = {}
local tabBtns = {}
local currentTab = 0

for i, data in ipairs(tabData) do
    local page = Instance.new("Frame")
    page.Name = "Page_" .. data.name
    page.Size = UDim2.new(1, 0, 0, 0)
    page.AutomaticSize = Enum.AutomaticSize.Y
    page.BackgroundTransparency = 1
    page.Visible = false
    page.ZIndex = 8
    page.Parent = ContentScroll

    makeList(page, Enum.FillDirection.Vertical, 8, Enum.HorizontalAlignment.Center)
    pad(page, 10, 10, 14, 14)

    tabPages[i] = page
end

local function selectTab(index)
    if currentTab == index then return end
    if tabData[index] == nil then return end
    if not tabData[index].isKey and not keyValidated then return end
    if tabData[index].locked and not keyValidated then return end

    for _, page in ipairs(tabPages) do
        page.Visible = false
    end

    ContentScroll.CanvasPosition = Vector2.new(0, 0)

    if tabPages[index] then
        tabPages[index].Visible = true
    end

    for i, btn in ipairs(tabBtns) do
        if btn and btn.Parent then
            if i == index then
                tw(btn, 0.25, {BackgroundColor3 = C.accent, BackgroundTransparency = 0.85})
                if btn:FindFirstChild("Label") then
                    tw(btn.Label, 0.25, {TextColor3 = C.accent})
                end
            else
                tw(btn, 0.25, {BackgroundColor3 = C.sidebar, BackgroundTransparency = 1})
                if btn:FindFirstChild("Label") then
                    local col = C.textDim
                    if tabData[i] and tabData[i].locked and not keyValidated then
                        col = C.textMuted
                    end
                    tw(btn.Label, 0.25, {TextColor3 = col})
                end
            end
        end
    end

    if tabData[index] then
        PageTitle.Text = tabData[index].name
    end
    currentTab = index
end

local function removeKeyTab()
    if tabBtns[1] and tabBtns[1].Parent then
        tabBtns[1]:Destroy()
    end
    if tabPages[1] and tabPages[1].Parent then
        tabPages[1]:Destroy()
    end
    table.remove(tabBtns, 1)
    table.remove(tabPages, 1)
    table.remove(tabData, 1)
    currentTab = 0
end

local function unlockAllTabs()
    keyValidated = true
    for i, data in ipairs(tabData) do
        data.locked = false
        if tabBtns[i] and tabBtns[i].Parent then
            if tabBtns[i]:FindFirstChild("Label") then
                tw(tabBtns[i].Label, 0.3, {TextColor3 = C.textDim})
            end
            local lock = tabBtns[i]:FindFirstChild("LockIcon")
            if lock then
                tw(lock, 0.2, {TextTransparency = 1})
                task.delay(0.3, function()
                    if lock.Parent then lock:Destroy() end
                end)
            end
        end
    end
end

for i, data in ipairs(tabData) do
    local btn = Instance.new("TextButton")
    btn.Name = "TabBtn_" .. data.name
    btn.Size = UDim2.new(1, 0, 0, 32)
    btn.BackgroundColor3 = C.sidebar
    btn.BackgroundTransparency = 1
    btn.BorderSizePixel = 0
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.ZIndex = 8
    btn.LayoutOrder = i
    btn.Parent = TabContainer
    corner(btn, 6)

    local icon = Instance.new("TextLabel")
    icon.Name = "Icon"
    icon.Size = UDim2.new(0, 22, 1, 0)
    icon.Position = UDim2.new(0, 8, 0, 0)
    icon.BackgroundTransparency = 1
    icon.Text = data.icon
    icon.TextSize = 13
    icon.ZIndex = 9
    icon.Parent = btn

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Size = UDim2.new(1, -50, 1, 0)
    label.Position = UDim2.new(0, 32, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = data.name
    label.TextColor3 = data.locked and C.textMuted or C.textDim
    label.TextSize = 12
    label.Font = Enum.Font.GothamSemibold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.ZIndex = 9
    label.Parent = btn

    if data.locked then
        local lockIcon = Instance.new("TextLabel")
        lockIcon.Name = "LockIcon"
        lockIcon.Size = UDim2.new(0, 14, 1, 0)
        lockIcon.Position = UDim2.new(1, -18, 0, 0)
        lockIcon.BackgroundTransparency = 1
        lockIcon.Text = "\xF0\x9F\x94\x92"
        lockIcon.TextSize = 9
        lockIcon.ZIndex = 9
        lockIcon.Parent = btn
    end

    btn.MouseEnter:Connect(function()
        local idx = table.find(tabBtns, btn)
        if idx and currentTab ~= idx then
            if tabData[idx] and (not tabData[idx].locked or keyValidated) then
                tw(btn, 0.15, {BackgroundTransparency = 0.9, BackgroundColor3 = C.card})
            end
        end
    end)
    btn.MouseLeave:Connect(function()
        local idx = table.find(tabBtns, btn)
        if idx and currentTab ~= idx then
            tw(btn, 0.15, {BackgroundTransparency = 1, BackgroundColor3 = C.sidebar})
        end
    end)
    btn.MouseButton1Click:Connect(function()
        local idx = table.find(tabBtns, btn)
        if idx then
            if tabData[idx] and tabData[idx].locked and not keyValidated then return end
            selectTab(idx)
        end
    end)

    tabBtns[i] = btn
end

