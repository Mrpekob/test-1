local function refreshAllCensoredText()
    pcall(function()
        for _, obj in ipairs(PlayerGui:GetDescendants()) do
            if obj.Parent and not isOurGui(obj) then
                if obj:IsA("TextLabel") or obj:IsA("TextBox") or obj:IsA("TextButton") then
                    pcall(function()
                        local orig = originalTexts[obj]
                        local baseText = orig or obj.Text
                        if textContainsAnyName(baseText) then
                            originalTexts[obj] = baseText
                            local censored = censorText(baseText)
                            if censored ~= obj.Text then obj.Text = censored end
                        end
                    end)
                end
            end
        end
    end)
    pcall(function()
        local coreGui = game:GetService("CoreGui")
        for _, obj in ipairs(coreGui:GetDescendants()) do
            if obj:IsA("TextLabel") or obj:IsA("TextBox") or obj:IsA("TextButton") then
                pcall(function()
                    local orig = originalTexts[obj]
                    local baseText = orig or obj.Text
                    if textContainsAnyName(baseText) then
                        originalTexts[obj] = baseText
                        local censored = censorText(baseText)
                        if censored ~= obj.Text then obj.Text = censored end
                    end
                end)
            end
        end
    end)
end

