        keyStatus.TextColor3 = C.yellow 
        return 
    end
    keySubmitText.Text = "Checking..."
    tw(keySubmit, 0.15, {BackgroundColor3 = C.textMuted})
    task.wait(0.8)
    if not guiAlive then return end
    if entered == CORRECT_KEY then
        keyStatus.Text = "Key validated successfully!"
        keyStatus.TextColor3 = C.green
        tw(keySubmit, 0.3, {BackgroundColor3 = C.green})
        keySubmitText.Text = "Unlocked!"
        createNotification("Success", "Key validated! All features unlocked.", 3, C.green)
        task.wait(0.5)
        if not guiAlive then return end
        unlockAllTabs()
        task.wait(0.3)
        if not guiAlive then return end
        removeKeyTab()
        selectTab(1)
    else
        keyStatus.Text = "Invalid key. Please try again."
        keyStatus.TextColor3 = C.red
        tw(keySubmit, 0.2, {BackgroundColor3 = C.red})
        keySubmitText.Text = "Invalid Key"
        local orig = keyInputFrame.Position
        for _ = 1, 3 do
            tw(keyInputFrame, 0.04, {Position = orig + UDim2.new(0, 8, 0, 0)}, Enum.EasingStyle.Linear) 
