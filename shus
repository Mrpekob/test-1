    corner(btn, isMobile and 8 or 6)

    local icon = Instance.new("TextLabel")
    icon.Name = "Icon"
    icon.Size = UDim2.new(0, isMobile and 24 or 22, 1, 0)
    icon.Position = UDim2.new(0, isMobile and 6 or 8, 0, 0)
    icon.BackgroundTransparency = 1
    icon.Text = data.icon
    icon.TextSize = isMobile and 15 or 13
    icon.TextColor3 = C.textDim
    icon.ZIndex = 9
    icon.Parent = btn

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Size = UDim2.new(1, isMobile and -55 or -50, 1, 0)
    label.Position = UDim2.new(0, isMobile and 28 or 32, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = isMobile and data.name:sub(1, 4) or data.name
    label.TextColor3 = data.locked and C.textMuted or C.textDim
    label.TextSize = isMobile and 13 or 12
    label.Font = Enum.Font.GothamSemibold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.ZIndex = 9
    label.Parent = btn

    if data.locked then
        local lockIcon = Instance.new("TextLabel")
        lockIcon.Name = "LockIcon"
        lockIcon.Size = UDim2.new(0, isMobile and 16 or 14, 1, 0)
        lockIcon.Position = UDim2.new(1, isMobile and -20 or -18, 0, 0)
        lockIcon.BackgroundTransparency = 1
        lockIcon.Text = "🔒"
        lockIcon.TextSize = isMobile and 10 or 9
        lockIcon.ZIndex = 9
        lockIcon.Parent = btn
    end

    btn.MouseButton1Click:Connect(function()
        if not guiAlive then return end
        local idx = table.find(tabBtns, btn)
        if idx then
            if tabData[idx] and tabData[idx].locked and not keyValidated then return end
            tw(btn, 0.1, {BackgroundTransparency = 0.85}, Enum.EasingStyle.Linear)
            task.wait(0.1)
            tw(btn, 0.15, {BackgroundTransparency = currentTab == idx and 0.85 or 1})
            selectTab(idx)
        end
    end)

    if not isMobile then
        btn.MouseEnter:Connect(function()
            if not guiAlive then return end
            local idx = table.find(tabBtns, btn)
            if idx and currentTab ~= idx and tabData[idx] and (not tabData[idx].locked or keyValidated) then
                tw(btn, 0.15, {BackgroundTransparency = 0.9, BackgroundColor3 = C.card})
            end
        end)
        btn.MouseLeave:Connect(function()
            if not guiAlive then return end
            local idx = table.find(tabBtns, btn)
            if idx and currentTab ~= idx then
                tw(btn, 0.15, {BackgroundTransparency = 1, BackgroundColor3 = C.sidebar})
            end
        end)
    end

    tabBtns[i] = btn
end

