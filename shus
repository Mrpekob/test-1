                if not humanoid or not _G.BossClapperRunning then
                    _G.BossClapperRegisteredModels[target] = nil
                    return
                end

                local hitPart = target:FindFirstChild("HumanoidRootPart")
                    or target:FindFirstChild("Torso")
                    or target:FindFirstChild("Head")

                if not hitPart then
                    task.wait(0.5)
                    hitPart = target:FindFirstChild("HumanoidRootPart")
                        or target:FindFirstChild("Torso")
                        or target:FindFirstChild("Head")
                end

                if not hitPart or not _G.BossClapperRunning then
                    _G.BossClapperRegisteredModels[target] = nil
                    return
                end

                if target.Parent == sdFolderBC and humanoid.Health > 0 then
                    table.insert(_G.BossClapperActiveTargets, {
                        model = target,
                        humanoid = humanoid,
                        hitPart = hitPart
                    })
                else
                    _G.BossClapperRegisteredModels[target] = nil
                end
            end)
        end

        -- Register all existing targets
        for _, child in ipairs(sdFolderBC:GetChildren()) do
            registerTargetBC(child)
        end

