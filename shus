    -- Helper function to read current and max juice from the UI
    local function getJuiceValues()
        local current, maxJuice = nil, nil
        pcall(function()
            local juiceUI = LocalPlayer.PlayerGui:FindFirstChild("RealityMovementUI")
            if not juiceUI then return end
            local juiceLabel = juiceUI:FindFirstChild("RealityJuice", true)
            if not juiceLabel then return end

            local text = ""
            if juiceLabel:IsA("TextLabel") or juiceLabel:IsA("TextButton") or juiceLabel:IsA("TextBox") then
                text = juiceLabel.Text
            else
                for _, desc in ipairs(juiceLabel:GetDescendants()) do
                    if (desc:IsA("TextLabel") or desc:IsA("TextButton") or desc:IsA("TextBox")) and desc.Text:find("/") then
                        text = desc.Text
                        break
                    end
                end
            end

            local cur, mx = text:match("(%d+)%s*/%s*(%d+)")
            if cur and mx then
                current = tonumber(cur)
                maxJuice = tonumber(mx)
            end
        end)
        return current, maxJuice
    end

