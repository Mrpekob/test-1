local function isOurGui(obj)
    local current = obj
    while current do
        if current == ScreenGui then return true end
        if current.Name == "BossFucker" then return true end
        current = current.Parent
    end
    return false
end

local function plainReplace(text, search, replace)
    if not search or search == "" then return text end
    local result = ""
    local searchLen = #search
    local i = 1
    while i <= #text do
        if text:sub(i, i + searchLen - 1) == search then
            result = result .. replace
            i = i + searchLen
        else
            result = result .. text:sub(i, i)
            i = i + 1
        end
    end
    return result
end

local function textContainsAnyName(text)
    if not text or text == "" then return false end
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Name and player.Name ~= "" and text:find(player.Name, 1, true) then return true end
        if player.DisplayName and player.DisplayName ~= "" and player.DisplayName ~= player.Name and text:find(player.DisplayName, 1, true) then return true end
    end
    return false
end

local function censorText(text)
    if not nameHiderEnabled then return text end
    if not text or text == "" then return text end
    local replacements = {}
    for _, player in ipairs(Players:GetPlayers()) do
        pcall(function()
            if player.Name and player.Name ~= "" then
                if player == LocalPlayer then
                    if player.DisplayName and player.DisplayName ~= "" and player.DisplayName ~= player.Name then
                        table.insert(replacements, {name = player.DisplayName, replace = customFakeName, len = #player.DisplayName})
                    end
                    table.insert(replacements, {name = player.Name, replace = customFakeName, len = #player.Name})
                else
                    if player.DisplayName and player.DisplayName ~= "" and player.DisplayName ~= player.Name then
                        table.insert(replacements, {name = player.DisplayName, replace = HIDDEN_PLACEHOLDER, len = #player.DisplayName})
                    end
                    table.insert(replacements, {name = player.Name, replace = HIDDEN_PLACEHOLDER, len = #player.Name})
                end
            end
        end)
    end
    table.sort(replacements, function(a, b) return a.len > b.len end)
    for _, rep in ipairs(replacements) do
        text = plainReplace(text, rep.name, rep.replace)
    end
    return text
end

local function watchTextObject(obj)
    if not obj then return end
    if isOurGui(obj) then return end
    pcall(function()
        if originalTexts[obj] == nil then originalTexts[obj] = obj.Text end
        local censored = censorText(obj.Text)
        if censored ~= obj.Text then obj.Text = censored end
        local conn = obj:GetPropertyChangedSignal("Text"):Connect(function()
            if not nameHiderEnabled or not guiAlive then return end
            if isOurGui(obj) then return end
            pcall(function()
                local currentText = obj.Text
                if currentText:find(HIDDEN_PLACEHOLDER, 1, true) then return end
                if customFakeName ~= LocalPlayer.Name and currentText:find(customFakeName, 1, true) then return end
                if textContainsAnyName(currentText) then
                    originalTexts[obj] = currentText
                    local newCensored = censorText(currentText)
                    if newCensored ~= currentText then obj.Text = newCensored end
                end
            end)
        end)
        table.insert(nameHiderConnections, conn)
    end)
end

local function scanAndHideGui(gui)
    if not gui then return end
    if isOurGui(gui) then return end
    pcall(function()
        for _, obj in ipairs(gui:GetDescendants()) do
            if (obj:IsA("TextLabel") or obj:IsA("TextBox") or obj:IsA("TextButton")) and not isOurGui(obj) then
                watchTextObject(obj)
            end
        end
        local conn = gui.DescendantAdded:Connect(function(obj)
            if not nameHiderEnabled or not guiAlive then return end
            if isOurGui(obj) then return end
            task.wait(0.05)
            pcall(function()
                if obj:IsA("TextLabel") or obj:IsA("TextBox") or obj:IsA("TextButton") then
                    watchTextObject(obj)
                end
            end)
        end)
        table.insert(nameHiderConnections, conn)
    end)
end

local function hideCharacterNames(character)
    if not character then return end
    pcall(function()
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            if not originalHumanoidSettings[humanoid] then
                originalHumanoidSettings[humanoid] = {
                    DisplayDistanceType = humanoid.DisplayDistanceType,
                    NameDisplayDistance = humanoid.NameDisplayDistance,
                    HealthDisplayDistance = humanoid.HealthDisplayDistance,
                }
            end
            humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
            humanoid.NameDisplayDistance = 0
            humanoid.HealthDisplayDistance = 0
        end
    end)
    pcall(function()
        for _, obj in ipairs(character:GetDescendants()) do
            if obj:IsA("BillboardGui") then
                if not originalBillboardSettings[obj] then
                    originalBillboardSettings[obj] = {Enabled = obj.Enabled, MaxDistance = obj.MaxDistance}
                end
                obj.Enabled = false
                obj.MaxDistance = 0
                for _, child in ipairs(obj:GetDescendants()) do
                    if child:IsA("TextLabel") or child:IsA("TextButton") then
                        if not originalBillboardTextSettings[child] then
                            originalBillboardTextSettings[child] = {TextTransparency = child.TextTransparency, BackgroundTransparency = child.BackgroundTransparency}
                        end
                        child.TextTransparency = 1
                        child.BackgroundTransparency = 1
                    end
                end
            end
        end
    end)
    pcall(function()
        local conn = character.DescendantAdded:Connect(function(obj)
            if not nameHiderEnabled or not guiAlive then return end
            task.wait(0.05)
            pcall(function()
                if obj:IsA("BillboardGui") then
                    if not originalBillboardSettings[obj] then
                        originalBillboardSettings[obj] = {Enabled = obj.Enabled, MaxDistance = obj.MaxDistance}
                    end
                    obj.Enabled = false
                    obj.MaxDistance = 0
                    for _, child in ipairs(obj:GetDescendants()) do
                        if child:IsA("TextLabel") or child:IsA("TextButton") then
                            if not originalBillboardTextSettings[child] then
                                originalBillboardTextSettings[child] = {TextTransparency = child.TextTransparency, BackgroundTransparency = child.BackgroundTransparency}
                            end
                            child.TextTransparency = 1
                            child.BackgroundTransparency = 1
                        end
                    end
                elseif (obj:IsA("TextLabel") or obj:IsA("TextButton")) and obj.Parent and obj.Parent:IsA("BillboardGui") then
                    if not originalBillboardTextSettings[obj] then
                        originalBillboardTextSettings[obj] = {TextTransparency = obj.TextTransparency, BackgroundTransparency = obj.BackgroundTransparency}
                    end
                    obj.TextTransparency = 1
                    obj.BackgroundTransparency = 1
                end
            end)
        end)
        table.insert(nameHiderConnections, conn)
    end)
end

local function showCharacterNames(character)
    if not character then return end
    pcall(function()
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            local saved = originalHumanoidSettings[humanoid]
            if saved then
                humanoid.DisplayDistanceType = saved.DisplayDistanceType
                humanoid.NameDisplayDistance = saved.NameDisplayDistance
                humanoid.HealthDisplayDistance = saved.HealthDisplayDistance
                originalHumanoidSettings[humanoid] = nil
            else
                humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.Viewer
                humanoid.NameDisplayDistance = 100
                humanoid.HealthDisplayDistance = 100
            end
        end
    end)
    pcall(function()
        for _, obj in ipairs(character:GetDescendants()) do
            if obj:IsA("BillboardGui") then
                local saved = originalBillboardSettings[obj]
                if saved then
                    obj.Enabled = saved.Enabled
                    obj.MaxDistance = saved.MaxDistance
                    originalBillboardSettings[obj] = nil
                else
                    obj.Enabled = true
                    obj.MaxDistance = 100
                end
                for _, child in ipairs(obj:GetDescendants()) do
                    if child:IsA("TextLabel") or child:IsA("TextButton") then
                        local savedText = originalBillboardTextSettings[child]
                        if savedText then
                            child.TextTransparency = savedText.TextTransparency
                            child.BackgroundTransparency = savedText.BackgroundTransparency
                            originalBillboardTextSettings[child] = nil
                        else
                            child.TextTransparency = 0
                        end
                    end
                end
            end
        end
    end)
end

local function restoreAllTexts()
    for obj, origText in pairs(originalTexts) do
        pcall(function()
            if obj and obj.Parent and not isOurGui(obj) then obj.Text = origText end
        end)
    end
    originalTexts = {}
end

local function enableNameHider()
    nameHiderEnabled = true
    originalTexts = {}
    updateHomePlayerCard()

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if player.Character then hideCharacterNames(player.Character) end
            local conn = player.CharacterAdded:Connect(function(char)
                if not guiAlive or not nameHiderEnabled then return end
                task.wait(0.1)
                hideCharacterNames(char)
            end)
            table.insert(nameHiderConnections, conn)
        end
    end

    local playerAddedConn = Players.PlayerAdded:Connect(function(player)
        if not guiAlive or not nameHiderEnabled then return end
        if player.Character then hideCharacterNames(player.Character) end
        local conn = player.CharacterAdded:Connect(function(char)
            if not guiAlive or not nameHiderEnabled then return end
            task.wait(0.1)
            hideCharacterNames(char)
        end)
        table.insert(nameHiderConnections, conn)
    end)
    table.insert(nameHiderConnections, playerAddedConn)

    for _, gui in ipairs(PlayerGui:GetChildren()) do
        if not isOurGui(gui) then pcall(function() scanAndHideGui(gui) end) end
    end
    local pgConn = PlayerGui.ChildAdded:Connect(function(gui)
        if not guiAlive or not nameHiderEnabled then return end
        if isOurGui(gui) then return end
        task.wait(0.1)
        pcall(function() scanAndHideGui(gui) end)
    end)
    table.insert(nameHiderConnections, pgConn)

    pcall(function()
        local coreGui = game:GetService("CoreGui")
        for _, gui in ipairs(coreGui:GetChildren()) do
            pcall(function() scanAndHideGui(gui) end)
        end
        local cgConn = coreGui.ChildAdded:Connect(function(gui)
            if not guiAlive or not nameHiderEnabled then return end
            task.wait(0.1)
            pcall(function() scanAndHideGui(gui) end)
        end)
        table.insert(nameHiderConnections, cgConn)
    end)

    local heartbeatConn = RunService.Heartbeat:Connect(function()
        if not guiAlive or not nameHiderEnabled then return end
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                pcall(function()
                    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                    if humanoid and humanoid.NameDisplayDistance ~= 0 then
                        humanoid.NameDisplayDistance = 0
                        humanoid.HealthDisplayDistance = 0
                    end
                    for _, obj in ipairs(player.Character:GetDescendants()) do
                        if obj:IsA("BillboardGui") and (obj.Enabled or obj.MaxDistance ~= 0) then
                            obj.Enabled = false
                            obj.MaxDistance = 0
                        end
                    end
                end)
            end
        end
    end)
    table.insert(nameHiderConnections, heartbeatConn)

    task.spawn(function()
        while nameHiderEnabled and guiAlive do
            task.wait(0.5)
            if not nameHiderEnabled or not guiAlive then break end
            pcall(function()
                for _, obj in ipairs(PlayerGui:GetDescendants()) do
                    if obj.Parent and not isOurGui(obj) then
                        if obj:IsA("TextLabel") or obj:IsA("TextBox") or obj:IsA("TextButton") then
                            pcall(function()
                                local currentText = obj.Text
                                if currentText:find(HIDDEN_PLACEHOLDER, 1, true) then return end
                                if customFakeName ~= LocalPlayer.Name and currentText:find(customFakeName, 1, true) then return end
                                if textContainsAnyName(currentText) then
                                    originalTexts[obj] = currentText
                                    local censored = censorText(currentText)
                                    if censored ~= currentText then obj.Text = censored end
                                end
                            end)
                        end
                    end
                end
            end)
            pcall(function()
                local coreGui = game:GetService("CoreGui")
                for _, obj in ipairs(coreGui:GetDescendants()) do
                    if obj:IsA("TextLabel") or obj:IsA("TextBox") or obj:IsA("TextButton") then
                        pcall(function()
                            local currentText = obj.Text
                            if currentText:find(HIDDEN_PLACEHOLDER, 1, true) then return end
                            if customFakeName ~= LocalPlayer.Name and currentText:find(customFakeName, 1, true) then return end
                            if textContainsAnyName(currentText) then
                                originalTexts[obj] = currentText
                                local censored = censorText(currentText)
                                if censored ~= currentText then obj.Text = censored end
                            end
                        end)
                    end
                end
            end)
        end
    end)
end

local function disableNameHider()
    nameHiderEnabled = false
    for _, conn in ipairs(nameHiderConnections) do
        pcall(function() conn:Disconnect() end)
    end
    nameHiderConnections = {}
    restoreAllTexts()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            pcall(function() showCharacterNames(player.Character) end)
        end
    end
    originalHumanoidSettings = {}
    originalBillboardSettings = {}
    originalBillboardTextSettings = {}
    updateHomePlayerCard()
end

