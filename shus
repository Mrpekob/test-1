local tabData = {
    {name = "Key",      icon = "🔑", locked = false, isKey = true},
    {name = "Home",     icon = "🏠", locked = true},
    {name = "Combat",   icon = "⚔",  locked = true},
    {name = "Player",   icon = "👤", locked = true},
    {name = "Teleport", icon = "📍", locked = true},
    {name = "Misc",     icon = "⚙",  locked = true},
}

local tabPages = {}
local tabBtns = {}
local currentTab = 0

for i, data in ipairs(tabData) do
    local page = Instance.new("Frame")
    page.Name = "Page_" .. data.name
    page.Size = UDim2.new(1, 0, 0, 0)
    page.AutomaticSize = Enum.AutomaticSize.Y
    page.BackgroundTransparency = 1
    page.Visible = false
    page.ZIndex = 8
    page.Parent = ContentScroll
    makeList(page, Enum.FillDirection.Vertical, isMobile and 10 or 8, Enum.HorizontalAlignment.Center)
    pad(page, isMobile and 12 or 10, isMobile and 12 or 10, isMobile and 12 or 14, isMobile and 12 or 14)
    tabPages[i] = page
end

local function selectTab(index)
    if not guiAlive then return end
    if currentTab == index then return end
    if tabData[index] == nil then return end
    if not tabData[index].isKey and not keyValidated then return end
    if tabData[index].locked and not keyValidated then return end
    for _, page in ipairs(tabPages) do page.Visible = false end
    ContentScroll.CanvasPosition = Vector2.new(0, 0)
    if tabPages[index] then tabPages[index].Visible = true end
    for i, btn in ipairs(tabBtns) do
        if btn and btn.Parent then
            if i == index then
                tw(btn, 0.25, {BackgroundColor3 = C.accent, BackgroundTransparency = 0.85})
                if btn:FindFirstChild("Label") then tw(btn.Label, 0.25, {TextColor3 = C.accent}) end
                if btn:FindFirstChild("Icon") then tw(btn.Icon, 0.25, {TextColor3 = C.accent}) end
            else
                tw(btn, 0.25, {BackgroundColor3 = C.sidebar, BackgroundTransparency = 1})
                if btn:FindFirstChild("Label") then
                    tw(btn.Label, 0.25, {TextColor3 = (tabData[i] and tabData[i].locked and not keyValidated) and C.textMuted or C.textDim})
                end
                if btn:FindFirstChild("Icon") then
                    tw(btn.Icon, 0.25, {TextColor3 = C.textDim})
                end
            end
        end
    end
    if tabData[index] then PageTitle.Text = tabData[index].name end
    currentTab = index
end

local function removeKeyTab()
    if tabBtns[1] and tabBtns[1].Parent then tabBtns[1]:Destroy() end
    if tabPages[1] and tabPages[1].Parent then tabPages[1]:Destroy() end
    table.remove(tabBtns, 1)
    table.remove(tabPages, 1)
    table.remove(tabData, 1)
    currentTab = 0
end

local function unlockAllTabs()
    keyValidated = true
    for i, data in ipairs(tabData) do
        data.locked = false
        if tabBtns[i] and tabBtns[i].Parent then
            if tabBtns[i]:FindFirstChild("Label") then tw(tabBtns[i].Label, 0.3, {TextColor3 = C.textDim}) end
            local lock = tabBtns[i]:FindFirstChild("LockIcon")
            if lock then
                tw(lock, 0.2, {TextTransparency = 1})
                task.delay(0.3, function() if lock.Parent then lock:Destroy() end end)
            end
        end
    end
end

for i, data in ipairs(tabData) do
    local btn = Instance.new("TextButton")
    btn.Name = "TabBtn_" .. data.name
    btn.Size = UDim2.new(1, 0, 0, isMobile and 38 or 32)
    btn.BackgroundColor3 = C.sidebar
