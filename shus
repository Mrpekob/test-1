-- AUTO REVIVE SYSTEM
-- ============================
local autoReviveEnabled = false
local autoReviveThread = nil

local REVIVE_DELAY = 0.2
local CHECK_INTERVAL = 1
local RETURN_AFTER_REVIVE = true
local MAX_ATTEMPTS_PER_PLAYER = 20
local RETRY_DELAY = 0.3

-- Background proximity loop specifically for revive
local reviveProximityThread = nil

local function startReviveProximityLoop()
    if reviveProximityThread then return end
    reviveProximityThread = task.spawn(function()
        while autoReviveEnabled and guiAlive do
            for _, descendant in ipairs(workspace:GetDescendants()) do
                if descendant:IsA("ProximityPrompt") then
                    descendant.HoldDuration = 0
                    descendant.MaxActivationDistance = 25
                end
            end
            task.wait(1)
        end
        reviveProximityThread = nil
    end)
end

local function stopReviveProximityLoop()
    reviveProximityThread = nil
end

local function fireRevivePrompt(prompt)
    if not prompt or not prompt.Parent then return false end
    if fireproximityprompt then
        fireproximityprompt(prompt)
        return true
    end
    local oldHoldDuration = prompt.HoldDuration
    prompt.HoldDuration = 0
    prompt:InputHoldBegin()
    task.wait()
    prompt:InputHoldEnd()
    prompt.HoldDuration = oldHoldDuration
    return true
end

local function reviveHasHighlight(character)
    if not character then return false end
    for _, child in pairs(character:GetChildren()) do
        if child:IsA("Highlight") then return true end
    end
    return false
end

local function reviveIsLocalPlayerAFK()
    local success, result = pcall(function()
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        local playerStatus = playerGui.RobloxGui.PlayerListContainer.ScrollList[LocalPlayer.Name].BGFrame.PlayerName.PlayerStatus
        if playerStatus:IsA("TextLabel") or playerStatus:IsA("TextBox") then
            return playerStatus.Text ~= ""
        end
        return false
    end)
    return success and result or false
end

local function getRevivePrompt(character)
    if not character then return nil end
    local head = character:FindFirstChild("Head")
    if not head then return nil end
    for _, descendant in pairs(head:GetDescendants()) do
        if descendant:IsA("ProximityPrompt") and string.find(string.lower(descendant.Name), "revive") then
            return descendant
        end
    end
    return nil
end

local function reviveIsInsideSD(character)
    local SD = workspace:FindFirstChild("SD")
    return SD and character.Parent == SD
end

local function reviveUntilDone(player, character)
    local attempts = 0
    print("[Auto Revive] Starting persistent revive on: " .. player.Name)

    while attempts < MAX_ATTEMPTS_PER_PLAYER and autoReviveEnabled and guiAlive do

        if reviveIsLocalPlayerAFK() then
            print("[Auto Revive] YOU went AFK! Stopping revive on " .. player.Name)
            return false
        end

        local currentChar = LocalPlayer.Character
        if not currentChar then return false end

        local HRP = currentChar:FindFirstChild("HumanoidRootPart")
        if not HRP then return false end

        -- Check if already revived
        local freshChar = workspace:FindFirstChild(player.Name)
        if not freshChar then return true end
        if reviveIsInsideSD(freshChar) then return true end
        if not reviveHasHighlight(freshChar) then
            print("[Auto Revive] " .. player.Name .. " confirmed ALIVE!")
            return true
        end

        attempts = attempts + 1
        print("[Auto Revive] Attempt " .. attempts .. "/" .. MAX_ATTEMPTS_PER_PLAYER .. " on " .. player.Name)

        local targetHead = freshChar:FindFirstChild("Head")
        if not targetHead then
            task.wait(RETRY_DELAY)
            continue
        end

        -- Teleport next to target
        HRP.CFrame = targetHead.CFrame * CFrame.new(0, 0, 2)
        task.wait(REVIVE_DELAY)

        -- Get fresh prompt and fire
        local prompt = getRevivePrompt(freshChar)
        if prompt then
            fireRevivePrompt(prompt)
            print("[Auto Revive] Fired prompt (attempt " .. attempts .. ")")
        else
            print("[Auto Revive] No prompt found on attempt " .. attempts)
        end

        task.wait(RETRY_DELAY)
    end

    if attempts >= MAX_ATTEMPTS_PER_PLAYER then
        print("[Auto Revive] Gave up on " .. player.Name .. " after max attempts.")
    end
    return false
end

local function autoReviveLoop()
    print("[Auto Revive] Loop started.")
    while autoReviveEnabled and guiAlive do

        local Character = LocalPlayer.Character
        local HRP = Character and Character:FindFirstChild("HumanoidRootPart")

        if not Character or not HRP then
            task.wait(CHECK_INTERVAL)
            continue
        end

        if reviveIsLocalPlayerAFK() then
            task.wait(CHECK_INTERVAL)
            continue
        end

        local originalPosition = HRP.CFrame
        local playersToRevive = {}

        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local char = workspace:FindFirstChild(player.Name)
                if char and not reviveIsInsideSD(char) and reviveHasHighlight(char) then
                    local prompt = getRevivePrompt(char)
                    if prompt then
                        table.insert(playersToRevive, {
                            player = player,
                            character = char,
                        })
                    end
                end
            end
        end

        if #playersToRevive > 0 then
            print("[Auto Revive] Found " .. #playersToRevive .. " dead player(s).")
            createNotification("Auto Revive", "Found " .. #playersToRevive .. " player(s) to revive!", 3, C.cyan)

            for _, data in pairs(playersToRevive) do
                if not autoReviveEnabled or not guiAlive then break end
                if reviveIsLocalPlayerAFK() or not LocalPlayer.Character then break end

                local freshChar = workspace:FindFirstChild(data.player.Name)
                if not freshChar or reviveIsInsideSD(freshChar) or not reviveHasHighlight(freshChar) then
                    continue
                end

                reviveUntilDone(data.player, freshChar)
            end

            if RETURN_AFTER_REVIVE then
                local currentChar = LocalPlayer.Character
                if currentChar then
                    local currentHRP = currentChar:FindFirstChild("HumanoidRootPart")
                    if currentHRP then
                        currentHRP.CFrame = originalPosition
                        print("[Auto Revive] Returned to original position.")
                    end
                end
            end
        end

        task.wait(CHECK_INTERVAL)
    end
    print("[Auto Revive] Loop stopped.")
end

local function startAutoRevive()
    if autoReviveThread then return end
    autoReviveEnabled = true
    startReviveProximityLoop()
    autoReviveThread = task.spawn(autoReviveLoop)
    createNotification("Auto Revive", "Auto revive enabled! Watching for dead players.", 3, C.green)
end

local function stopAutoRevive()
    autoReviveEnabled = false
    stopReviveProximityLoop()
    autoReviveThread = nil
    createNotification("Auto Revive", "Auto revive disabled.", 2, C.yellow)
    print("[Auto Revive] Stopped.")
end

