local sdFolder = workspace:WaitForChild("SD")
local allowedTools = {["HEX Spitter"] = true, ["Whig gun deluxe"] = true}
local activeLoops = {}
local autoAttackEnabled = false
local infAttackEnabled = false
local cachedRemote = nil
local lastRemoteCheck = 0
local REMOTE_CACHE_TIME = 0.3

local function getRemote()
    if not guiAlive then return nil end
    local now = tick()
    if cachedRemote and (now - lastRemoteCheck) < REMOTE_CACHE_TIME then
        if cachedRemote.Parent then return cachedRemote end
        cachedRemote = nil
    end
    local character = LocalPlayer.Character
    if not character then character = LocalPlayer.CharacterAdded:Wait() end
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local searchLocations = {character}
    if backpack then table.insert(searchLocations, backpack) end
    for _, location in ipairs(searchLocations) do
        for toolName in pairs(allowedTools) do
            local tool = location:FindFirstChild(toolName)
            if tool then
                local remotes = tool:FindFirstChild("Remotes")
                if remotes then
                    local serverControl = remotes:FindFirstChild("ServerControl")
                    if serverControl then cachedRemote = serverControl lastRemoteCheck = now return serverControl end
                end
            end
        end
    end
    cachedRemote = nil
    return nil
end

local function waitForRemote(timeout)
    local start = tick()
    timeout = timeout or 10
    while (tick() - start) < timeout do
        if not guiAlive then return nil end
        local remote = getRemote()
        if remote then return remote end
        task.wait(0.2)
    end
    return nil
end

local function getTorso(target)
    return target:FindFirstChild("Torso") or target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("Head")
end

local function isValidTarget(target)
    if not target or not target.Parent then return false end
    if target.Parent ~= sdFolder then return false end
    if not getTorso(target) then return false end
    local humanoid = target:FindFirstChildOfClass("Humanoid")
    if humanoid and humanoid.Health <= 0 then return false end
    return true
end

local function startTargetLoop(target)
    if activeLoops[target] then return end
    activeLoops[target] = true
    task.spawn(function()
        local failCount = 0
        while guiAlive and autoAttackEnabled and isValidTarget(target) do
            local remote = getRemote()
            if not remote then task.wait(0.5) remote = waitForRemote(5) if not remote then task.wait(1) continue end end
            local torso = getTorso(target)
            if torso then
                local ok = pcall(function() remote:InvokeServer("RayHit", {Hit = torso, Position = torso.Position}) end)
                if ok then failCount = 0
                else failCount += 1 cachedRemote = nil if failCount >= 20 then task.wait(2) failCount = 0 end end
            end
            task.wait(0.01)
        end
        activeLoops[target] = nil
    end)
end

local function startAllLoops()
    if not guiAlive then return end
    for _, child in ipairs(sdFolder:GetChildren()) do
        if isValidTarget(child) and not activeLoops[child] then startTargetLoop(child) end
    end
end

local function stopEverything()
    autoAttackEnabled = false
    infAttackEnabled = false
    cachedRemote = nil
    task.delay(0.5, function() table.clear(activeLoops) end)
end

