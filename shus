    corner(knobF, isMobile and 8 or 6)

    local sliding = false
    local inputBtn = Instance.new("TextButton")
    inputBtn.Size = UDim2.new(1, isMobile and 12 or 10, 0, isMobile and 24 or 20)
    inputBtn.Position = UDim2.new(0, isMobile and -6 or -5, 0, isMobile and -9 or -8)
    inputBtn.BackgroundTransparency = 1
    inputBtn.Text = ""
    inputBtn.ZIndex = 13
    inputBtn.Parent = trackBG

    local function update(inputPos)
        if not guiAlive then return end
        local abs = trackBG.AbsolutePosition.X
        local w = trackBG.AbsoluteSize.X
        local rel = math.clamp((inputPos.X - abs) / w, 0, 1)
        local val = math.floor(min + (max - min) * rel + 0.5)
        local newPct = (val - min) / (max - min)
        fill.Size = UDim2.new(newPct, 0, 1, 0)
        knobF.Position = UDim2.new(newPct, isMobile and -8 or -6, 0.5, isMobile and -8 or -6)
        valLbl.Text = tostring(val)
        if callback then callback(val) end
    end

    inputBtn.MouseButton1Down:Connect(function() sliding = true end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
            sliding = false 
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if not guiAlive then return end
        if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then 
            update(input.Position) 
        end
    end)
    
    inputBtn.MouseButton1Click:Connect(function()
        if not guiAlive then return end
        local mousePos = UserInputService:GetMouseLocation()
        update(mousePos)
    end)

